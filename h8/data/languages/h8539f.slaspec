# MULXU <EAs>,Rd           Multiply extend as unsigned
#       N = res s< 0
#       Z = res == 0
#       V = 0
#       C = 0
:mulxu.b      eab_direct      ,Rd    is eab_direct;       opcode=21 & Rd                 { op1:2 = zext(Rd[0,8]); op2:2 = zext(eab_direct      ); result:2 = op1 * op2; Rd = result       ; stdflags(result); $(CF) = 0; }
